{
  "name": "onward",
  "version": "1.10.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:reset": "prisma migrate reset",
    "db:seed": "node --import=tsx prisma/seed.ts",
    "check": "svelte-kit sync && svelte-check --fail-on-warnings",
    "format": "prettier --check \"**/*.{svelte,js,ts,md,html,css,json,yaml}\"",
    "lint": "eslint \"**/*.{svelte,js,ts}\"",
    "prepare": "svelte-kit sync || echo '' && node \"./.husky/install.js\""
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1000.0",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@valkey/valkey-glide": "2.0.1",
    "openai": "^5.22.0",
    "weaviate-client": "^3.8.1",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@lucide/svelte": "^0.511.0",
    "@sveltejs/adapter-node": "^5.2.12",
    "@sveltejs/enhanced-img": "^0.8.1",
    "@sveltejs/kit": "^2.57.0",
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "@tailwindcss/typography": "^0.5.18",
    "@tailwindcss/vite": "^4.1.18",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.2.9",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.10.1",
    "@vitest/coverage-v8": "3.1.4",
    "date-fns": "^4.1.0",
    "dompurify": "^3.3.2",
    "dotenv": "^17.2.2",
    "eslint": "^9.39.3",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-svelte": "^3.15.0",
    "globals": "^16.2.0",
    "google-auth-library": "^10.5.0",
    "husky": "^9.1.7",
    "jsdom": "^27.3.0",
    "lint-staged": "^16.1.2",
    "marked": "^16.3.0",
    "nanoid": "^5.1.6",
    "pino": "^10.0.0",
    "pino-pretty": "^13.1.1",
    "prettier": "^3.6.2",
    "prettier-plugin-svelte": "^3.4.0",
