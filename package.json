    "prisma": "^7.7.0",
    "svelte": "^5.55.2",
    "svelte-check": "^4.3.0",
    "tailwindcss": "^4.1.11",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.56.1",
    "uuid": "^13.0.0",
    "vite": "^7.3.2",
    "vitest": "^3.1.4"
  },
  "pnpm": {
    "overrides": {
      "@hono/node-server": ">=1.19.13",
      "hono": ">=4.11.10",
      "fast-xml-parser": ">=5.3.8",
      "cookie": ">=0.7.0"
    }
